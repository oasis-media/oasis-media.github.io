---
import MenuLayout from "../layouts/MenuLayout.astro";
import Head from "../layouts/Head.astro";
import { Image } from 'astro:assets';

import index from '.././assets/img/index.png';
import countries from "../data/countries.json";

interface Post {
    url: string;
    frontmatter: {
        code: string;
        [key: string]: any;
    };
}

interface Country {
    alpha2Code: string;
    region: string;
    translations: { fr: string; [key: string]: string | null };
    [key: string]: any;
}

const matches = import.meta.glob<Post>("./carte/*.md", { eager: true });
const posts = Object.values(matches)


const ids: string[] = [];
posts.forEach((post: Post) => {
    ids.push(post.frontmatter.code);
});


const matchedCountries = countries.filter((c) =>
    ids.includes(c.alpha2Code)
);

interface PostData {
    url: string;
    code: string;
    title: string;
    region: string | undefined;
}

const data: PostData[] = posts.map((post: Post) => {
    const country = matchedCountries.find(
        (c) => c.alpha2Code === post.frontmatter.code
    );
    return {
        url: post.url,
        code: post.frontmatter.code,
        title: post.frontmatter.country,
        region: country?.region,
    };
});


